<?php
/**
 * Tenant Schedule / Calendar Page
 * Interactive day/week schedule view with availability, filtering, and booking links.
 */
?>

<div x-data="schedulePage()" x-init="init()">
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-surface-900 to-surface-800 text-white py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-3xl sm:text-4xl font-extrabold">Schedule</h1>
            <p class="mt-3 text-lg text-surface-300 max-w-2xl">Book your spot — browse upcoming sessions by date.</p>
        </div>
    </section>

    <!-- Controls Bar -->
    <section class="bg-white border-b border-surface-100 sticky top-16 z-30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <!-- Date Navigation -->
                <div class="flex items-center gap-2">
                    <button @click="prevWeek()" class="p-2 rounded-lg hover:bg-surface-100 text-surface-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <button @click="goToday()" class="px-3 py-1.5 text-sm font-semibold rounded-lg bg-primary-50 text-primary-600 hover:bg-primary-100 transition-colors">Today</button>
                    <button @click="nextWeek()" class="p-2 rounded-lg hover:bg-surface-100 text-surface-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                    <span class="ml-2 text-sm font-bold text-surface-800" x-text="weekLabel()"></span>
                </div>

                <!-- View Toggle -->
                <div class="flex items-center gap-2">
                    <div class="flex bg-surface-100 rounded-lg p-0.5">
                        <button @click="viewMode = 'week'" class="px-3 py-1.5 text-xs font-bold rounded-md transition-colors"
                                :class="viewMode === 'week' ? 'bg-white text-surface-800 shadow-sm' : 'text-surface-500 hover:text-surface-700'">Week</button>
                        <button @click="viewMode = 'list'" class="px-3 py-1.5 text-xs font-bold rounded-md transition-colors"
                                :class="viewMode === 'list' ? 'bg-white text-surface-800 shadow-sm' : 'text-surface-500 hover:text-surface-700'">List</button>
                    </div>
                    <!-- Category Filter -->
                    <select x-model="categoryFilter" @change="load()" class="text-sm border border-surface-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
                        <option value="">All Categories</option>
                        <template x-for="c in categories" :key="c.id">
                            <option :value="c.id" x-text="c.name"></option>
                        </template>
                    </select>
                </div>
            </div>
        </div>
    </section>

    <!-- Loading -->
    <div x-show="loading" class="py-20 text-center">
        <div class="inline-flex items-center gap-3 text-surface-400">
            <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            Loading schedule...
        </div>
    </div>

    <!-- ═══ WEEK VIEW ═══ -->
    <section x-show="!loading && viewMode === 'week'" class="py-8 bg-surface-50 min-h-[60vh]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Day columns -->
            <div class="grid grid-cols-7 gap-3">
                <template x-for="day in weekDays" :key="day.key">
                    <div class="min-h-[200px]">
                        <!-- Day header -->
                        <div class="text-center mb-3 pb-2 border-b-2"
                             :class="isToday(day.date) ? 'border-primary-500' : 'border-surface-200'">
                            <div class="text-xs font-bold uppercase tracking-wider"
                                 :class="isToday(day.date) ? 'text-primary-500' : 'text-surface-400'"
                                 x-text="day.label"></div>
                            <div class="text-lg font-extrabold mt-0.5"
                                 :class="isToday(day.date) ? 'text-primary-600' : 'text-surface-800'"
                                 x-text="day.dayNum"></div>
                        </div>
                        <!-- Slots for that day -->
                        <div class="space-y-2">
                            <template x-for="s in dayClasses(day.key)" :key="s.id">
                                <a :href="'/schedule/' + s.id"
                                   class="block p-2.5 rounded-xl border text-left transition-all hover:shadow-md hover:-translate-y-0.5 duration-200"
                                   :class="s.is_full ? 'bg-surface-50 border-surface-200 opacity-60' : 'bg-white border-surface-100 hover:border-primary-200'">
                                    <div class="flex items-start gap-1.5">
                                        <div class="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0" :style="'background:' + (s.category_color || '#6366f1')"></div>
                                        <div class="min-w-0 flex-1">
                                            <div class="text-[11px] text-surface-400 font-medium" x-text="formatTime(s.start_time)"></div>
                                            <div class="text-xs font-bold text-surface-800 truncate" x-text="s.session_type_name || 'Session'"></div>
                                            <div class="mt-1 text-[10px] font-semibold"
                                                 :class="s.is_full ? 'text-red-500' : 'text-primary-500'"
                                                 x-text="s.is_full ? 'Full' : s.spots_left + ' left'"></div>
                                        </div>
                                    </div>
                                </a>
                            </template>
                            <div x-show="dayClasses(day.key).length === 0" class="text-center py-6 text-xs text-surface-300">—</div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </section>

    <!-- ═══ LIST VIEW ═══ -->
    <section x-show="!loading && viewMode === 'list'" class="py-8 bg-surface-50 min-h-[60vh]">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-3">
            <template x-for="day in weekDays" :key="day.key">
                <div x-show="dayClasses(day.key).length > 0" class="bg-white rounded-2xl border border-surface-100 overflow-hidden">
                    <!-- Day header -->
                    <div class="px-5 py-3 bg-surface-50 border-b border-surface-100">
                        <span class="text-sm font-bold text-surface-800" x-text="day.fullLabel"></span>
                        <span x-show="isToday(day.date)" class="ml-2 text-xs font-bold text-primary-500 bg-primary-50 px-2 py-0.5 rounded-full">Today</span>
                    </div>
                    <!-- Sessions -->
                    <div class="divide-y divide-surface-50">
                        <template x-for="s in dayClasses(day.key)" :key="s.id">
                            <a :href="'/schedule/' + s.id" class="flex items-center gap-4 px-5 py-4 hover:bg-surface-50 transition-colors group">
                                <!-- Time -->
                                <div class="w-20 flex-shrink-0">
                                    <div class="text-sm font-bold text-surface-800" x-text="formatTime(s.start_time)"></div>
                                    <div class="text-xs text-surface-400" x-text="formatTime(s.end_time)"></div>
                                </div>
                                <!-- Color bar -->
                                <div class="w-1 h-10 rounded-full flex-shrink-0" :style="'background:' + (s.category_color || '#6366f1')"></div>
                                <!-- Details -->
                                <div class="flex-1 min-w-0">
                                    <div class="text-sm font-bold text-surface-900 group-hover:text-primary-600 transition-colors" x-text="s.session_type_name || 'Session'"></div>
                                    <div class="text-xs text-surface-400 mt-0.5">
                                        <span x-text="s.category_name || 'General'"></span>
                                        <span x-show="s.skill_levels">· <span x-text="s.skill_levels"></span></span>
                                    </div>
                                </div>
                                <!-- Availability -->
                                <div class="text-right flex-shrink-0">
                                    <div class="text-sm font-bold"
                                         :class="s.is_full ? 'text-red-500' : 'text-primary-500'"
                                         x-text="s.is_full ? 'Full' : s.spots_left + ' spots left'"></div>
                                    <div x-show="s.price > 0" class="text-xs text-surface-500 mt-0.5" x-text="'$' + parseFloat(s.price).toFixed(2)"></div>
                                    <div x-show="!s.price || s.price == 0" class="text-xs text-primary-500 mt-0.5 font-semibold">Free</div>
                                </div>
                                <svg class="w-4 h-4 text-surface-300 group-hover:text-primary-500 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                        </template>
                    </div>
                </div>
            </template>

            <!-- Empty -->
            <div x-show="classes.length === 0" class="text-center py-20">
                <div class="w-16 h-16 rounded-full bg-surface-100 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <p class="text-lg font-semibold text-surface-600">No sessions this week</p>
                <p class="text-sm text-surface-400 mt-1">Try a different week or remove filters.</p>
            </div>
        </div>
    </section>
</div>

<script>
function schedulePage() {
    return {
        classes: [],
        categories: [],
        weekStart: null,
        viewMode: 'week',
        categoryFilter: '',
        loading: true,

        init() {
            this.weekStart = this.getMonday(new Date());
            this.loadCategories();
            this.load();
            window.addEventListener('facility-changed', () => this.load());
        },

        getMonday(d) {
            const dt = new Date(d);
            const day = dt.getDay();
            const diff = dt.getDate() - day + (day === 0 ? -6 : 1);
            dt.setDate(diff);
            dt.setHours(0, 0, 0, 0);
            return dt;
        },

        get weekDays() {
            const days = [];
            const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const fullNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
            for (let i = 0; i < 7; i++) {
                const d = new Date(this.weekStart);
                d.setDate(d.getDate() + i);
                days.push({
                    key: d.toISOString().split('T')[0],
                    date: new Date(d),
                    label: dayNames[i],
                    fullLabel: fullNames[i] + ', ' + d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
                    dayNum: d.getDate()
                });
            }
            return days;
        },

        weekLabel() {
            const end = new Date(this.weekStart);
            end.setDate(end.getDate() + 6);
            const opts = { month: 'short', day: 'numeric' };
            return this.weekStart.toLocaleDateString('en-US', opts) + ' – ' + end.toLocaleDateString('en-US', opts);
        },

        isToday(d) {
            const today = new Date();
            return d.toDateString() === today.toDateString();
        },

        prevWeek() {
            this.weekStart = new Date(this.weekStart.setDate(this.weekStart.getDate() - 7));
            this.load();
        },
        nextWeek() {
            this.weekStart = new Date(this.weekStart.setDate(this.weekStart.getDate() + 7));
            this.load();
        },
        goToday() {
            this.weekStart = this.getMonday(new Date());
            this.load();
        },

        async loadCategories() {
            try {
                const res = await fetch(baseApi + '/api/public/categories');
                const json = await res.json();
                this.categories = json.data || [];
            } catch(e) {}
        },

        async load() {
            this.loading = true;
            const start = this.weekStart.toISOString().split('T')[0];
            const end = new Date(this.weekStart);
            end.setDate(end.getDate() + 6);
            const endStr = end.toISOString().split('T')[0];

            let url = baseApi + '/api/public/schedule?start=' + start + '&end=' + endStr;
            const fac = window.tenantApp?.selectedFacility || JSON.parse(localStorage.getItem('selected_facility') || 'null');
            if (fac?.id) url += '&facility_id=' + fac.id;
            else if (ORG.facilities.length) url += '&facility_id=' + ORG.facilities[0].id;
            if (this.categoryFilter) url += '&category_id=' + this.categoryFilter;

            try {
                const res = await fetch(url);
                const json = await res.json();
                this.classes = json.data || [];
            } catch(e) {
                this.classes = [];
            }
            this.loading = false;
        },

        dayClasses(dateKey) {
            return this.classes.filter(c => {
                if (!c.start_time) return false;
                return c.start_time.substring(0, 10) === dateKey;
            });
        },

        formatTime(dt) {
            if (!dt) return '';
            const d = new Date(dt);
            return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
        }
    };
}
</script>
