<?php
/**
 * Tenant Facilities (Locations) Listing Page
 * Grid of facilities with address, court count, and links.
 */
?>

<section class="bg-gradient-to-br from-surface-900 to-surface-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-extrabold">Our Locations</h1>
        <p class="mt-3 text-lg text-surface-300 max-w-2xl">Find a facility near you and explore our courts and amenities.</p>
    </div>
</section>

<section class="py-12 bg-surface-50 min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <?php if (empty($facilities)): ?>
        <div class="text-center py-20">
            <div class="w-16 h-16 rounded-full bg-surface-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            </div>
            <p class="text-lg font-semibold text-surface-600">No locations available</p>
        </div>
        <?php else: ?>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <?php foreach ($facilities as $f): ?>
            <a href="/facilities/<?= htmlspecialchars($f['slug']) ?>" class="group block bg-white rounded-2xl border border-surface-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                <!-- Header image area -->
                <div class="h-48 bg-gradient-to-br from-primary-100 to-primary-50 relative flex items-center justify-center">
                    <svg class="w-16 h-16 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    <?php if (!empty($f['is_indoor'])): ?>
                    <span class="absolute top-3 right-3 text-[10px] font-bold px-2 py-0.5 rounded-full bg-white/80 text-surface-600">Indoor</span>
                    <?php endif; ?>
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-surface-900 group-hover:text-primary-600 transition-colors"><?= htmlspecialchars($f['name']) ?></h3>
                    <?php if (!empty($f['address_line1'])): ?>
                    <p class="mt-2 text-sm text-surface-500">
                        <?= htmlspecialchars($f['address_line1']) ?>
                        <?php if (!empty($f['city'])): ?><br><?= htmlspecialchars($f['city']) ?><?php if (!empty($f['state'])): ?>, <?= htmlspecialchars($f['state']) ?><?php endif; ?><?php if (!empty($f['zip_code'])): ?> <?= htmlspecialchars($f['zip_code']) ?><?php endif; ?><?php endif; ?>
                    </p>
                    <?php elseif (!empty($f['city'])): ?>
                    <p class="mt-2 text-sm text-surface-500"><?= htmlspecialchars($f['city'] . (!empty($f['state']) ? ', ' . $f['state'] : '')) ?></p>
                    <?php endif; ?>

                    <?php if (!empty($f['phone'])): ?>
                    <p class="mt-2 text-sm text-surface-400"><?= htmlspecialchars($f['phone']) ?></p>
                    <?php endif; ?>

                    <div class="mt-4 pt-4 border-t border-surface-50 flex items-center justify-between">
                        <span class="text-xs text-surface-400"><?= htmlspecialchars($f['court_count'] ?? '—') ?> Court<?= ($f['court_count'] ?? 0) != 1 ? 's' : '' ?></span>
                        <span class="text-sm font-semibold text-primary-600 group-hover:gap-3 inline-flex items-center gap-2 transition-all">
                            View Details
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </div>
                </div>
            </a>
            <?php endforeach; ?>
        </div>
        <?php endif; ?>
    </div>
</section>
