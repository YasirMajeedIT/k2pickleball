<?php
/**
 * Player Dashboard — Profile Settings
 * Edit personal info and change password.
 */
?>

<div x-data="profilePage()" x-init="load()">
    <h1 class="text-2xl font-extrabold text-surface-900 mb-2">Profile Settings</h1>
    <p class="text-sm text-surface-500 mb-8">Manage your personal information and password.</p>

    <!-- Personal Info -->
    <div class="bg-white rounded-2xl border border-surface-100 p-6 sm:p-8 mb-6">
        <h2 class="text-lg font-bold text-surface-800 mb-6">Personal Information</h2>
        <form @submit.prevent="saveProfile()" class="space-y-4 max-w-lg">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-xs font-semibold text-surface-600 block mb-1.5">First Name</label>
                    <input x-model="profile.first_name" type="text" required
                           class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
                </div>
                <div>
                    <label class="text-xs font-semibold text-surface-600 block mb-1.5">Last Name</label>
                    <input x-model="profile.last_name" type="text" required
                           class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
                </div>
            </div>
            <div>
                <label class="text-xs font-semibold text-surface-600 block mb-1.5">Email</label>
                <input x-model="profile.email" type="email" required
                       class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
            </div>
            <div>
                <label class="text-xs font-semibold text-surface-600 block mb-1.5">Phone</label>
                <input x-model="profile.phone" type="tel"
                       class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
            </div>

            <div x-show="profileMsg" class="text-sm" :class="profileSuccess ? 'text-green-600' : 'text-red-500'" x-text="profileMsg"></div>

            <button type="submit" :disabled="savingProfile"
                    class="px-6 py-2.5 text-sm font-bold text-white bg-primary-500 hover:bg-primary-600 rounded-xl transition-colors disabled:opacity-50">
                <span x-show="!savingProfile">Save Changes</span>
                <span x-show="savingProfile">Saving...</span>
            </button>
        </form>
    </div>

    <!-- Change Password -->
    <div class="bg-white rounded-2xl border border-surface-100 p-6 sm:p-8">
        <h2 class="text-lg font-bold text-surface-800 mb-6">Change Password</h2>
        <form @submit.prevent="changePassword()" class="space-y-4 max-w-lg">
            <div>
                <label class="text-xs font-semibold text-surface-600 block mb-1.5">Current Password</label>
                <input x-model="pw.current" type="password" required
                       class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
            </div>
            <div>
                <label class="text-xs font-semibold text-surface-600 block mb-1.5">New Password</label>
                <input x-model="pw.password" type="password" required minlength="8"
                       class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none"
                       placeholder="Min 8 characters">
            </div>
            <div>
                <label class="text-xs font-semibold text-surface-600 block mb-1.5">Confirm New Password</label>
                <input x-model="pw.password_confirmation" type="password" required
                       class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none">
            </div>

            <div x-show="pwMsg" class="text-sm" :class="pwSuccess ? 'text-green-600' : 'text-red-500'" x-text="pwMsg"></div>

            <button type="submit" :disabled="savingPw"
                    class="px-6 py-2.5 text-sm font-bold text-white bg-surface-800 hover:bg-surface-900 rounded-xl transition-colors disabled:opacity-50">
                <span x-show="!savingPw">Update Password</span>
                <span x-show="savingPw">Updating...</span>
            </button>
        </form>
    </div>
</div>

<script>
function profilePage() {
    return {
        profile: { first_name: '', last_name: '', email: '', phone: '' },
        pw: { current: '', password: '', password_confirmation: '' },
        savingProfile: false,
        profileMsg: '',
        profileSuccess: false,
        savingPw: false,
        pwMsg: '',
        pwSuccess: false,

        load() {
            // Defer until dashboardApp loads player
            const check = () => {
                const app = document.querySelector('[x-data*=dashboardApp]')?.__x?.$data;
                if (app?.player) {
                    this.profile.first_name = app.player.first_name || '';
                    this.profile.last_name = app.player.last_name || '';
                    this.profile.email = app.player.email || '';
                    this.profile.phone = app.player.phone || '';
                } else {
                    setTimeout(check, 200);
                }
            };
            check();
        },

        async saveProfile() {
            this.profileMsg = '';
            this.savingProfile = true;
            try {
                const app = document.querySelector('[x-data*=dashboardApp]').__x.$data;
                const res = await app.authFetch(baseApi + '/api/auth/profile', {
                    method: 'PUT',
                    body: JSON.stringify(this.profile)
                });
                const json = await res.json();
                if (res.ok) {
                    this.profileSuccess = true;
                    this.profileMsg = 'Profile updated successfully.';
                    app.showToast('Profile updated', 'success');
                } else {
                    this.profileSuccess = false;
                    this.profileMsg = json.error || json.message || 'Failed to update profile.';
                }
            } catch(e) {
                this.profileSuccess = false;
                this.profileMsg = 'Something went wrong.';
            }
            this.savingProfile = false;
        },

        async changePassword() {
            this.pwMsg = '';
            if (this.pw.password !== this.pw.password_confirmation) {
                this.pwMsg = 'Passwords do not match.';
                this.pwSuccess = false;
                return;
            }
            this.savingPw = true;
            try {
                const app = document.querySelector('[x-data*=dashboardApp]').__x.$data;
                const res = await app.authFetch(baseApi + '/api/auth/change-password', {
                    method: 'POST',
                    body: JSON.stringify({
                        current_password: this.pw.current,
                        password: this.pw.password,
                        password_confirmation: this.pw.password_confirmation
                    })
                });
                const json = await res.json();
                if (res.ok) {
                    this.pwSuccess = true;
                    this.pwMsg = 'Password changed successfully.';
                    this.pw = { current: '', password: '', password_confirmation: '' };
                    app.showToast('Password updated', 'success');
                } else {
                    this.pwSuccess = false;
                    this.pwMsg = json.error || json.message || 'Failed to change password.';
                }
            } catch(e) {
                this.pwSuccess = false;
                this.pwMsg = 'Something went wrong.';
            }
            this.savingPw = false;
        }
    };
}
</script>
