<?php
/**
 * Player Dashboard — My Bookings Page
 * Lists all bookings with filtering by status (upcoming/past/cancelled).
 */
?>

<div x-data="myBookings()" x-init="load()">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-extrabold text-surface-900">My Bookings</h1>
            <p class="mt-1 text-sm text-surface-500">View and manage your session bookings.</p>
        </div>
        <a href="/schedule" class="px-4 py-2.5 text-sm font-bold text-white bg-primary-500 hover:bg-primary-600 rounded-xl transition-colors">
            + Book Session
        </a>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 bg-surface-100 rounded-xl p-1 mb-6 w-fit">
        <template x-for="tab in ['upcoming', 'past', 'cancelled']" :key="tab">
            <button @click="activeTab = tab; filter()"
                    class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors capitalize"
                    :class="activeTab === tab ? 'bg-white text-surface-800 shadow-sm' : 'text-surface-500 hover:text-surface-700'"
                    x-text="tab"></button>
        </template>
    </div>

    <!-- Loading -->
    <div x-show="loading" class="text-center py-12 text-surface-400 text-sm">Loading bookings...</div>

    <!-- Bookings list -->
    <div x-show="!loading" class="space-y-3">
        <template x-for="b in filtered" :key="b.id">
            <div class="bg-white rounded-2xl border border-surface-100 p-5 flex items-center gap-4">
                <!-- Date badge -->
                <div class="w-14 h-14 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0">
                    <div class="text-center">
                        <div class="text-[10px] font-bold text-primary-500 uppercase" x-text="formatMonth(b.start_time)"></div>
                        <div class="text-xl font-extrabold text-primary-700 -mt-0.5" x-text="formatDay(b.start_time)"></div>
                    </div>
                </div>
                <!-- Details -->
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-bold text-surface-800" x-text="b.session_type_name || b.session_name || 'Session'"></div>
                    <div class="text-xs text-surface-400 mt-0.5" x-text="formatDate(b.start_time) + ' · ' + formatTime(b.start_time) + ' – ' + formatTime(b.end_time)"></div>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-xs font-bold px-2 py-0.5 rounded-full"
                              :class="{
                                  'bg-green-100 text-green-700': b.status === 'registered',
                                  'bg-amber-100 text-amber-700': b.status === 'waitlisted',
                                  'bg-red-100 text-red-600': b.status === 'cancelled',
                                  'bg-surface-100 text-surface-600': !['registered','waitlisted','cancelled'].includes(b.status)
                              }"
                              x-text="b.status"></span>
                        <span x-show="b.amount_paid > 0" class="text-xs text-surface-400" x-text="'$' + parseFloat(b.amount_paid).toFixed(2) + ' paid'"></span>
                    </div>
                </div>
                <!-- Action -->
                <div class="flex-shrink-0">
                    <a :href="'/schedule/' + b.class_id" class="text-xs font-semibold text-primary-600 hover:text-primary-700">View →</a>
                </div>
            </div>
        </template>

        <!-- Empty -->
        <div x-show="filtered.length === 0" class="bg-white rounded-2xl border border-surface-100 p-10 text-center">
            <p class="text-sm text-surface-500">No <span x-text="activeTab"></span> bookings.</p>
            <a x-show="activeTab !== 'upcoming'" href="/schedule" class="inline-block mt-3 text-sm font-semibold text-primary-600">Browse schedule →</a>
        </div>
    </div>
</div>

<script>
function myBookings() {
    return {
        all: [],
        filtered: [],
        activeTab: 'upcoming',
        loading: true,

        async load() {
            this.loading = true;
            try {
                const app = document.querySelector('[x-data*=dashboardApp]').__x.$data;
                const res = await app.authFetch(baseApi + '/api/auth/me');
                const json = await res.json();
                this.all = json.data?.bookings || [];
                this.filter();
            } catch(e) {}
            this.loading = false;
        },

        filter() {
            const now = new Date();
            if (this.activeTab === 'upcoming') {
                this.filtered = this.all.filter(b => b.status !== 'cancelled' && new Date(b.start_time) >= now);
            } else if (this.activeTab === 'past') {
                this.filtered = this.all.filter(b => b.status !== 'cancelled' && new Date(b.start_time) < now);
            } else {
                this.filtered = this.all.filter(b => b.status === 'cancelled');
            }
            this.filtered.sort((a, b) => this.activeTab === 'past'
                ? new Date(b.start_time) - new Date(a.start_time)
                : new Date(a.start_time) - new Date(b.start_time)
            );
        },

        formatMonth(dt) { return dt ? new Date(dt).toLocaleDateString('en-US', { month: 'short' }) : ''; },
        formatDay(dt) { return dt ? new Date(dt).getDate() : ''; },
        formatDate(dt) { return dt ? new Date(dt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) : ''; },
        formatTime(dt) { return dt ? new Date(dt).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) : ''; },
    };
}
</script>
