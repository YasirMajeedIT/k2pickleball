                                       placeholder="How can we help?">
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-surface-600 block mb-1">Message *</label>
                                <textarea x-model="form.message" required rows="5"
                                          class="w-full px-4 py-2.5 text-sm border border-surface-200 rounded-xl focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 outline-none resize-none"
                                          placeholder="Your message..."></textarea>
                            </div>
                            <div x-show="error" class="text-sm text-red-500" x-text="error"></div>
                            <button type="submit" :disabled="sending"
                                    class="w-full sm:w-auto px-8 py-3 text-sm font-bold text-white bg-primary-500 hover:bg-primary-600 rounded-xl shadow-lg shadow-primary-500/25 disabled:opacity-50 transition-all">
                                <span x-show="!sending">Send Message</span>
                                <span x-show="sending">Sending...</span>
                            </button>
                        </form>
                    </div>
                    <div x-show="sent" class="text-center py-10">
                        <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-surface-800">Message Sent!</h3>
                        <p class="text-sm text-surface-500 mt-2">Thank you for reaching out. We'll get back to you as soon as possible.</p>
                        <button @click="reset()" class="mt-4 text-sm font-semibold text-primary-600 hover:text-primary-700">Send another message</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
function contactForm() {
    return {
        form: { first_name: '', last_name: '', email: '', subject: '', message: '' },
        sending: false,
        sent: false,
        error: '',

        async submit() {
            this.error = '';
            if (!this.form.first_name.trim() || !this.form.email.trim() || !this.form.subject.trim() || !this.form.message.trim()) {
                this.error = 'Please fill in all required fields.';
                return;
            }
            this.sending = true;
            // For now, show success — backend contact endpoint can be added later
            await new Promise(r => setTimeout(r, 800));
            this.sent = true;
            this.sending = false;
            if (window.tenantApp?.showToast) window.tenantApp.showToast('Message sent!', 'success');
        },

        reset() {
            this.form = { first_name: '', last_name: '', email: '', subject: '', message: '' };
            this.sent = false;
            this.error = '';
        }
    };
}
</script>
