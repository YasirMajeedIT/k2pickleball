<?php
/**
 * Tenant Reset Password Page
 * Standalone auth page — set new password with token from email.
 */
$orgName = htmlspecialchars($org['name'] ?? 'Sports Club');
$primaryColor = $branding['primary_color'] ?? '#6366f1';
$logoUrl = $branding['logo_url'] ?? '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set New Password — <?= $orgName ?></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
    <script>const baseApi = window.location.origin;</script>
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="w-full max-w-md" x-data="resetPage()">
        <div class="text-center mb-8">
            <?php if ($logoUrl): ?>
            <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= $orgName ?>" class="h-12 mx-auto mb-4">
            <?php else: ?>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-lg font-extrabold text-white mx-auto mb-4" style="background: <?= htmlspecialchars($primaryColor) ?>">
                <?= htmlspecialchars(strtoupper(substr($org['name'] ?? 'S', 0, 1))) ?>
            </div>
            <?php endif; ?>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
            <div x-show="!success">
                <h1 class="text-xl font-extrabold text-gray-900">Set new password</h1>
                <p class="mt-2 text-sm text-gray-500">Enter your new password below.</p>

                <form @submit.prevent="submit()" class="mt-6 space-y-4">
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">New Password</label>
                        <input x-model="password" type="password" required minlength="8"
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="Min 8 characters">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Confirm Password</label>
                        <input x-model="password_confirmation" type="password" required
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="Repeat password">
                    </div>
                    <div x-show="error" class="text-sm text-red-500" x-text="error"></div>
                    <button type="submit" :disabled="loading"
                            class="w-full py-3.5 text-sm font-bold text-white rounded-xl shadow-lg transition-all disabled:opacity-50"
                            style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <span x-show="!loading">Reset Password</span>
                        <span x-show="loading">Resetting...</span>
                    </button>
                </form>
            </div>

            <div x-show="success" class="text-center py-4">
                <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h2 class="text-lg font-bold text-gray-900">Password updated!</h2>
                <p class="mt-2 text-sm text-gray-500">Your password has been reset. You can now sign in.</p>
                <a href="/login" class="inline-block mt-4 px-6 py-3 text-sm font-bold text-white rounded-xl"
                   style="background: <?= htmlspecialchars($primaryColor) ?>">Sign In</a>
            </div>
        </div>

        <div class="mt-6 text-center">
            <a href="/login" class="text-sm text-gray-500 hover:text-gray-700 font-medium">Back to login</a>
        </div>
    </div>

    <script>
    function resetPage() {
        return {
            password: '',
            password_confirmation: '',
            loading: false,
            error: '',
            success: false,

            getToken() {
                const params = new URLSearchParams(window.location.search);
                return params.get('token') || '';
            },

            async submit() {
                this.error = '';
                if (this.password !== this.password_confirmation) {
                    this.error = 'Passwords do not match.';
                    return;
                }
                if (this.password.length < 8) {
                    this.error = 'Password must be at least 8 characters.';
                    return;
                }
                const token = this.getToken();
                if (!token) {
                    this.error = 'Invalid or expired reset link.';
                    return;
                }
                this.loading = true;
                try {
                    const res = await fetch(baseApi + '/api/auth/reset-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token, password: this.password, password_confirmation: this.password_confirmation })
                    });
                    const json = await res.json();
                    if (res.ok) {
                        this.success = true;
                    } else {
                        this.error = json.error || json.message || 'Could not reset password. The link may have expired.';
                    }
                } catch(e) {
                    this.error = 'Something went wrong. Please try again.';
                }
                this.loading = false;
            }
        };
    }
    </script>
</body>
</html>
