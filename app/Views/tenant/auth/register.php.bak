                            <label class="text-xs font-semibold text-gray-600 block mb-1.5">First Name *</label>
                            <input x-model="form.first_name" type="text" required
                                   class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="text-xs font-semibold text-gray-600 block mb-1.5">Last Name *</label>
                            <input x-model="form.last_name" type="text" required
                                   class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none">
                        </div>
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Email *</label>
                        <input x-model="form.email" type="email" required
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="your@email.com">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Phone *</label>
                        <input x-model="form.phone" type="tel" required
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="(555) 123-4567">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Password *</label>
                        <input x-model="form.password" type="password" required minlength="8"
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="Min 8 characters">
                    </div>
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Confirm Password *</label>
                        <input x-model="form.password_confirmation" type="password" required
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="Repeat password">
                    </div>

                    <div x-show="error" class="text-sm text-red-500 bg-red-50 border border-red-100 rounded-xl px-4 py-3" x-text="error"></div>

                    <button type="submit" :disabled="loading"
                            class="w-full py-3.5 text-sm font-bold text-white rounded-xl shadow-lg transition-all disabled:opacity-50"
                            style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <span x-show="!loading">Create Account</span>
                        <span x-show="loading" class="inline-flex items-center gap-2">
                            <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                            Creating account...
                        </span>
                    </button>
                </form>

                <p class="mt-8 text-center text-sm text-gray-500">
                    Already have an account?
                    <a href="/login" class="font-semibold text-blue-600 hover:text-blue-700">Sign in</a>
                </p>
                <div class="mt-6 text-center">
                    <a href="/" class="text-xs text-gray-400 hover:text-gray-600">← Back to home</a>
                </div>
            </div>
        </div>
    </div>

    <script>
    function registerPage() {
        return {
            form: { first_name: '', last_name: '', email: '', phone: '', password: '', password_confirmation: '' },
            loading: false,
            error: '',

            async submit() {
                this.error = '';
                if (this.form.password !== this.form.password_confirmation) {
                    this.error = 'Passwords do not match.';
                    return;
                }
                if (this.form.password.length < 8) {
                    this.error = 'Password must be at least 8 characters.';
                    return;
                }
                this.loading = true;
                try {
                    const payload = { ...this.form, organization_id: ORG_ID, role_slug: 'player' };
                    const res = await fetch(baseApi + '/api/auth/register', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const json = await res.json();
                    if (res.ok && json.data) {
                        if (json.data.access_token || json.data.token) {
                            localStorage.setItem('player_token', json.data.access_token || json.data.token);
                            if (json.data.refresh_token) localStorage.setItem('player_refresh', json.data.refresh_token);
                            window.location.href = '/dashboard';
                        } else {
                            // Registration successful but no auto-login
                            window.location.href = '/login?registered=1';
                        }
                    } else {
                        this.error = json.error || json.message || 'Registration failed. Please try again.';
                    }
                } catch(e) {
                    this.error = 'Something went wrong. Please try again.';
                }
                this.loading = false;
            }
        };
    }
    </script>
</body>
</html>
