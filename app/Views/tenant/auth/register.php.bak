        <!-- Right: Registration form -->
        <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
            <div class="w-full max-w-md">
                <div class="lg:hidden text-center mb-8">
                    <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= $orgName ?>" class="h-12 mx-auto">
                    <?php else: ?>
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-lg font-extrabold text-white mx-auto" style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <?= htmlspecialchars(strtoupper(substr($org['name'] ?? 'S', 0, 1))) ?>
                    </div>
                    <?php endif; ?>
                </div>

                <h1 class="text-2xl font-extrabold text-gray-900">Create your account</h1>
                <p class="mt-2 text-sm text-gray-500">Join <?= $orgName ?> to start booking sessions.</p>

                <form @submit.prevent="submit()" class="mt-8 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
