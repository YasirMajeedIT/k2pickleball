<?php
/**
 * Tenant Forgot Password Page
 * Standalone auth page — password reset request.
 */
$orgName = htmlspecialchars($org['name'] ?? 'Sports Club');
$primaryColor = $branding['primary_color'] ?? '#6366f1';
$logoUrl = $branding['logo_url'] ?? '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password — <?= $orgName ?></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
    <script>const baseApi = window.location.origin;</script>
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="w-full max-w-md" x-data="forgotPage()">
        <div class="text-center mb-8">
            <?php if ($logoUrl): ?>
            <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= $orgName ?>" class="h-12 mx-auto mb-4">
            <?php else: ?>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-lg font-extrabold text-white mx-auto mb-4" style="background: <?= htmlspecialchars($primaryColor) ?>">
                <?= htmlspecialchars(strtoupper(substr($org['name'] ?? 'S', 0, 1))) ?>
            </div>
            <?php endif; ?>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
            <!-- Request form -->
            <div x-show="!sent">
                <h1 class="text-xl font-extrabold text-gray-900">Reset your password</h1>
                <p class="mt-2 text-sm text-gray-500">Enter your email and we'll send you a link to reset your password.</p>

                <form @submit.prevent="submit()" class="mt-6 space-y-4">
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Email Address</label>
                        <input x-model="email" type="email" required autofocus
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="your@email.com">
                    </div>
                    <div x-show="error" class="text-sm text-red-500" x-text="error"></div>
                    <button type="submit" :disabled="loading"
                            class="w-full py-3.5 text-sm font-bold text-white rounded-xl shadow-lg transition-all disabled:opacity-50"
                            style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <span x-show="!loading">Send Reset Link</span>
                        <span x-show="loading">Sending...</span>
                    </button>
                </form>
            </div>

            <!-- Success state -->
            <div x-show="sent" class="text-center py-4">
                <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <h2 class="text-lg font-bold text-gray-900">Check your email</h2>
                <p class="mt-2 text-sm text-gray-500">If an account exists for that email, we've sent a password reset link.</p>
            </div>
        </div>

        <div class="mt-6 text-center space-x-4">
            <a href="/login" class="text-sm text-gray-500 hover:text-gray-700 font-medium">Back to login</a>
            <a href="/" class="text-sm text-gray-400 hover:text-gray-600">Home</a>
        </div>
    </div>

    <script>
    function forgotPage() {
        return {
            email: '',
            loading: false,
            error: '',
            sent: false,

            async submit() {
                this.error = '';
                this.loading = true;
                try {
                    const res = await fetch(baseApi + '/api/auth/forgot-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: this.email })
                    });
                    // Always show success (don't reveal if email exists)
                    this.sent = true;
                } catch(e) {
                    this.error = 'Something went wrong. Please try again.';
                }
                this.loading = false;
            }
        };
    }
    </script>
</body>
</html>
