<?php
/**
 * Tenant Login Page
 * Standalone auth page — no layout wrapper (rendered standalone by TenantController).
 */
$orgName = htmlspecialchars($org['name'] ?? 'Sports Club');
$primaryColor = $branding['primary_color'] ?? '#6366f1';
$logoUrl = $branding['logo_url'] ?? '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In — <?= $orgName ?></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
    <script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    primary: {
                        50: '<?= $primaryColor ?>0d', 100: '<?= $primaryColor ?>1a', 200: '<?= $primaryColor ?>33',
                        300: '<?= $primaryColor ?>4d', 400: '<?= $primaryColor ?>80', 500: '<?= $primaryColor ?>',
                        600: '<?= $primaryColor ?>e6', 700: '<?= $primaryColor ?>cc', 800: '<?= $primaryColor ?>b3', 900: '<?= $primaryColor ?>99'
                    }
                }
            }
        }
    }
    const baseApi = window.location.origin;
    </script>
</head>
<body class="min-h-screen bg-gray-50">
    <div class="min-h-screen flex" x-data="loginPage()">
        <!-- Left: Branding panel -->
        <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white items-center justify-center p-12">
            <div class="max-w-md text-center">
                <?php if ($logoUrl): ?>
                <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= $orgName ?>" class="h-16 mx-auto mb-8">
                <?php else: ?>
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-2xl font-extrabold mx-auto mb-8" style="background: <?= htmlspecialchars($primaryColor) ?>">
                    <?= htmlspecialchars(strtoupper(substr($org['name'] ?? 'S', 0, 1))) ?>
                </div>
                <?php endif; ?>
                <h2 class="text-3xl font-extrabold"><?= $orgName ?></h2>
                <p class="mt-4 text-lg text-gray-400"><?= htmlspecialchars($branding['tagline'] ?? 'Book. Play. Compete.') ?></p>
            </div>
        </div>

        <!-- Right: Login form -->
        <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
            <div class="w-full max-w-md">
                <!-- Mobile logo -->
                <div class="lg:hidden text-center mb-8">
                    <?php if ($logoUrl): ?>
                    <img src="<?= htmlspecialchars($logoUrl) ?>" alt="<?= $orgName ?>" class="h-12 mx-auto">
                    <?php else: ?>
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-lg font-extrabold text-white mx-auto" style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <?= htmlspecialchars(strtoupper(substr($org['name'] ?? 'S', 0, 1))) ?>
                    </div>
                    <?php endif; ?>
                </div>

                <h1 class="text-2xl font-extrabold text-gray-900">Welcome back</h1>
                <p class="mt-2 text-sm text-gray-500">Sign in to your account to continue.</p>

                <form @submit.prevent="submit()" class="mt-8 space-y-5">
                    <div>
                        <label class="text-xs font-semibold text-gray-600 block mb-1.5">Email Address</label>
                        <input x-model="email" type="email" required autofocus
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="your@email.com">
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-1.5">
                            <label class="text-xs font-semibold text-gray-600">Password</label>
                            <a href="/forgot-password" class="text-xs font-semibold text-blue-600 hover:text-blue-700">Forgot password?</a>
                        </div>
                        <input x-model="password" type="password" required
                               class="w-full px-4 py-3 text-sm border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none"
                               placeholder="••••••••">
                    </div>

                    <div x-show="error" class="text-sm text-red-500 bg-red-50 border border-red-100 rounded-xl px-4 py-3" x-text="error"></div>

                    <button type="submit" :disabled="loading"
                            class="w-full py-3.5 text-sm font-bold text-white rounded-xl shadow-lg transition-all disabled:opacity-50"
                            style="background: <?= htmlspecialchars($primaryColor) ?>">
                        <span x-show="!loading">Sign In</span>
                        <span x-show="loading" class="inline-flex items-center gap-2">
                            <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                            Signing in...
                        </span>
                    </button>
                </form>

                <p class="mt-8 text-center text-sm text-gray-500">
                    Don't have an account?
                    <a href="/register" class="font-semibold text-blue-600 hover:text-blue-700">Create one</a>
                </p>

                <div class="mt-6 text-center">
                    <a href="/" class="text-xs text-gray-400 hover:text-gray-600">← Back to home</a>
                </div>
            </div>
        </div>
    </div>

    <script>
    function loginPage() {
        return {
            email: '',
            password: '',
            loading: false,
            error: '',

            async submit() {
                this.error = '';
                this.loading = true;
                try {
                    const res = await fetch(baseApi + '/api/auth/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: this.email, password: this.password })
                    });
                    const json = await res.json();
                    if (res.ok && json.data) {
                        localStorage.setItem('player_token', json.data.access_token || json.data.token);
                        if (json.data.refresh_token) localStorage.setItem('player_refresh', json.data.refresh_token);
                        window.location.href = '/dashboard';
                    } else {
                        this.error = json.error || json.message || 'Invalid email or password.';
                    }
                } catch(e) {
                    this.error = 'Something went wrong. Please try again.';
                }
                this.loading = false;
            }
        };
    }
    </script>
</body>
</html>
