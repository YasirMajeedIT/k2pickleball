$orgName = htmlspecialchars($org['name'] ?? 'Sports Club');
$primaryColor = $branding['primary_color'] ?? '#6366f1';
$accentColor = $branding['accent_color'] ?? '#f59e0b';
$logoUrl = $branding['logo_url'] ?? '';

// ── Color generation ──
if (!function_exists('hexToHSL')) {
    function hexToHSL(string $hex): array {
        $hex = ltrim($hex, '#');
        if (strlen($hex) === 3) $hex = $hex[0].$hex[0].$hex[1].$hex[1].$hex[2].$hex[2];
        $r = hexdec(substr($hex,0,2))/255; $g = hexdec(substr($hex,2,2))/255; $b = hexdec(substr($hex,4,2))/255;
        $max = max($r,$g,$b); $min = min($r,$g,$b); $l = ($max+$min)/2;
        if ($max === $min) { $h=$s=0; } else {
            $d = $max-$min; $s = $l>0.5 ? $d/(2-$max-$min) : $d/($max+$min);
            if ($max===$r) $h = ($g-$b)/$d + ($g<$b?6:0);
            elseif ($max===$g) $h = ($b-$r)/$d + 2;
            else $h = ($r-$g)/$d + 4;
            $h *= 60;
        }
        return [$h, $s*100, $l*100];
    }
}

[$ph, $ps, $pl] = hexToHSL($primaryColor);

$currentPath = parse_url($_SERVER['REQUEST_URI'] ?? '/', PHP_URL_PATH);
