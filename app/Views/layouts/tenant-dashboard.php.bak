        <div class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg text-sm font-medium text-white"
             :class="toast.type === 'error' ? 'bg-red-500' : toast.type === 'info' ? 'bg-blue-500' : 'bg-green-500'">
            <span x-text="toast.message"></span>
        </div>
    </div>

    <script>
    function dashboardApp() {
        return {
            player: null,
            sidebarOpen: false,
            toast: { show: false, message: '', type: 'success' },

            async init() {
                const token = localStorage.getItem('player_token');
                if (!token) {
                    window.location.href = '/login';
                    return;
                }
                try {
                    const res = await fetch(baseApi + '/api/auth/me', {
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    if (res.ok) {
                        const json = await res.json();
                        this.player = json.data;
                    } else {
                        localStorage.removeItem('player_token');
                        localStorage.removeItem('player_refresh');
                        window.location.href = '/login';
                    }
                } catch(e) {
                    window.location.href = '/login';
                }
            },

            async authFetch(url, opts = {}) {
                const token = localStorage.getItem('player_token');
                if (!opts.headers) opts.headers = {};
                opts.headers['Authorization'] = 'Bearer ' + token;
                if (!opts.headers['Content-Type'] && opts.method && opts.method !== 'GET') {
                    opts.headers['Content-Type'] = 'application/json';
                }
                return fetch(url, opts);
            },

            async logout() {
                const refresh = localStorage.getItem('player_refresh');
                if (refresh) {
                    try {
                        await this.authFetch(baseApi + '/api/auth/logout', {
                            method: 'POST',
                            body: JSON.stringify({ refresh_token: refresh })
                        });
                    } catch(e) {}
                }
                localStorage.removeItem('player_token');
                localStorage.removeItem('player_refresh');
                window.location.href = '/login';
            },

            showToast(msg, type = 'success') {
                this.toast = { show: true, message: msg, type };
                setTimeout(() => this.toast.show = false, 4000);
            }
        };
    }
    </script>
</body>
</html>
