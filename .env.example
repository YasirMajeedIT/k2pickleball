# ============================================
# K2 Pickleball SaaS Platform
# Environment Configuration
# ============================================

# Application
APP_NAME="K2 Pickleball"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://k2pickleball.local
APP_TIMEZONE=America/New_York
APP_KEY=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=k2pickleball
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING
JWT_ALGO=HS256
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=2592000

# Square Payments
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Redis (optional - falls back to file cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=k2pb_

# File Storage
STORAGE_DISK=local
STORAGE_PATH=storage/uploads
MAX_UPLOAD_SIZE=10485760

# Mail (future)
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@k2pickleball.com
MAIL_FROM_NAME="K2 Pickleball"

# Rate Limiting
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_AUTH=5
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=debug
LOG_PATH=storage/logs

# Domain Configuration
PLATFORM_DOMAIN=platform.k2pickleball.local
ADMIN_DOMAIN=admin.k2pickleball.local
API_DOMAIN=api.k2pickleball.local
BASE_DOMAIN=k2pickleball.local
